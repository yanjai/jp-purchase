# Google Sheets 設定
# 從 Google Sheet 網址取得：https://docs.google.com/spreadsheets/d/<這裡>/edit
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# Sheet 分頁名稱（預設為「清單」）
GOOGLE_SHEET_NAME=清單

# Google Service Account 金鑰（JSON 整個貼入，需轉為單行或保留換行）
# 取得方式：Google Cloud Console > IAM > 服務帳戶 > 建立金鑰 (JSON)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
